# {{ ansible_managed }}
# NFS mount unit for {{ item.path }}

[Unit]
Description=NFS mount for {{ item.path }}
After=network-online.target
Wants=network-online.target
DefaultDependencies=no

[Mount]
What={{ item.src }}
Where={{ item.path }}
Type={{ item.fstype }}
Options={{ item.opts | default('nofail,hard,_netdev') }}
TimeoutSec=30

[Install]
WantedBy=multi-user.target
