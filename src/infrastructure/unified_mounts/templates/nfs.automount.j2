# {{ ansible_managed }}
# NFS automount unit for {{ item.path }}

[Unit]
Description=NFS automount for {{ item.path }}
After=network-online.target
Wants=network-online.target
DefaultDependencies=no

[Automount]
Where={{ item.path }}
DirectoryMode=0755
TimeoutIdleSec=600

[Install]
WantedBy=multi-user.target
