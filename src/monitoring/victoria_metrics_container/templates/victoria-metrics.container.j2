[Unit]
Description={{ victoria_metrics_service_description }}

[Container]
Image={{ victoria_metrics_container_image }}
ContainerName={{ victoria_metrics_container_name }}
Network={{ victoria_metrics_network_name }}
AutoUpdate=registry
LogDriver=journald
UserNS=keep-id
NoNewPrivileges=true
ReadOnly=true
PublishPort={{ victoria_metrics_container_port }}:8428
Volume={{ victoria_metrics_config_file }}:/etc/prometheus.yml:z
Volume={{ victoria_metrics_data_dir }}:/victoria-metrics-data:Z
Volume=/etc/localtime:/etc/localtime:ro
{% if victoria_metrics_snapshot_auth_key | length > 0 %}
Volume={{ victoria_metrics_snapshot_auth_key_file }}:/etc/snapshot-auth.key:ro,Z
{% endif %}
Exec='-promscrape.config=/etc/prometheus.yml' '-retentionPeriod={{ victoria_metrics_retention_period }}' '-dedup.minScrapeInterval={{ victoria_metrics_dedup_min_scrape_interval }}'{% if victoria_metrics_snapshot_auth_key | length > 0 %} '-snapshotAuthKey=file:///etc/snapshot-auth.key'{% endif %}

[Service]
Restart={{ victoria_metrics_service_restart }}
RestartSec={{ victoria_metrics_service_restart_sec }}

[Install]
WantedBy=default.target