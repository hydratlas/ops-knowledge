#!/bin/bash
# {{ ansible_managed }}
# パッシブ・プル同期: 自ノードが VIP を保持していない場合にのみ、
# VIP の NFS（アクティブ）のリポジトリ群をローカルへミラーする。
set -euo pipefail

VIP="{{ backup_pull_sync_vip_address }}"
IFACE="{{ backup_pull_sync_interface }}"
SRC="{{ backup_pull_sync_source_dir }}"
DST="{{ backup_pull_sync_local_dir }}"
LOG_TAG="backup-pull"

log() { logger -t "$LOG_TAG" -- "$*" || true; echo "$*"; }

# VIP を保持していれば自分がアクティブ（= ミラーの source）なのでプルしない。
# keepalived の状態ファイルではなく、実体（IP の有無）だけを見てフェイルオーバーに
# 自動追従する。
if ip -brief address show dev "$IFACE" | grep -qw "$VIP"; then
  log "This node holds the VIP ($VIP); active node is the source. Skipping."
  exit 0
fi

mkdir -p "$DST"
# restic リポジトリは内容アドレスの append 構造。--delete を付けた素のミラーで安全。
#   --delete       : アクティブで prune された pack を追従削除（重複排除の効果を維持）
#   --exclude=locks: 転送中の一時ロックを持ち込まない（パッシブは書かないので不要）
log "Passive node: mirroring restic repos from $SRC to $DST"
rsync -a --delete --exclude='locks/***' "$SRC/" "$DST/"
log "Mirror completed."
