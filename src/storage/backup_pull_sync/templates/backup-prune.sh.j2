#!/bin/bash
# {{ ansible_managed }}
# 世代刈り: VIP 保持状態（アクティブ/パッシブ）に応じた保持世代数で、
# 各アプリ・ディレクトリーの古い世代を削除する。各ノードが独立に刈る。
set -euo pipefail

VIP="{{ backup_pull_sync_vip_address }}"
IFACE="{{ backup_pull_sync_interface }}"
DST="{{ backup_pull_sync_local_dir }}"
RETAIN_ACTIVE={{ backup_pull_sync_retain_active }}
RETAIN_PASSIVE={{ backup_pull_sync_retain_passive }}
LOG_TAG="backup-prune"

log() { logger -t "$LOG_TAG" -- "$*" || true; echo "$*"; }

# 保持世代数は VIP 保持状態に従わせる（固定属性にしない）。
# VIP を持つ間はアクティブ（短い）、持たない間はパッシブ（長い）。
if ip -brief address show dev "$IFACE" | grep -qw "$VIP"; then
  RETAIN=$RETAIN_ACTIVE
  log "Active node (holds VIP $VIP): retaining $RETAIN generations per app."
else
  RETAIN=$RETAIN_PASSIVE
  log "Passive node: retaining $RETAIN generations per app."
fi

if [ ! -d "$DST" ]; then
  log "No backup dir $DST; nothing to prune."
  exit 0
fi

# $DST/<app>/<timestamp>/ の最終名世代（.tmp-* を除く）を世代名の降順で並べ、
# 新しい RETAIN 個を残して残りを削除する。世代名はソート可能なタイムスタンプ前提。
shopt -s nullglob
for app_dir in "$DST"/*/; do
  mapfile -t gens < <(
    find "$app_dir" -mindepth 1 -maxdepth 1 -type d ! -name '.tmp-*' -printf '%f\n' | sort -r
  )
  count=${#gens[@]}
  if [ "$count" -le "$RETAIN" ]; then
    continue
  fi
  for ((i = RETAIN; i < count; i++)); do
    log "Pruning old generation: ${app_dir}${gens[$i]}"
    rm -rf -- "${app_dir}${gens[$i]}"
  done
done
log "Prune completed."
